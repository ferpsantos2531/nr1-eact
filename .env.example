# ──────────────────────────────────────────────────────────────────────────────
# NR-1 Abrasel — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com credenciais reais.
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (Neon PostgreSQL) ──────────────────────────────────────────
# branch main:            use credenciais do branch Neon "main"
# branch sso-integration: use credenciais do branch Neon "sso-integration"
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET="uma-chave-secreta-longa-e-aleatoria-minimo-32-chars"

# ── URLs ──────────────────────────────────────────────────────────────────────
# main:            https://nr1-eact.vercel.app
# sso-integration: https://conexao.abrasel.com.br/nr1
NEXT_PUBLIC_APP_URL="https://sua-app.vercel.app"

# ── Integração SSO com Conexão Abrasel (apenas no branch sso-integration) ─────
CONEXAO_API_URL="https://conexao.abrasel.com.br/perfil/api"
CONEXAO_REDIRECT_URL="https://conexao.abrasel.com.br/entrar"
