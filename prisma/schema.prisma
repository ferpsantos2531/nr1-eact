generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Usuario é um mapeamento mínimo: id do Conexão → permissão admin no NR-1.
// Dados de perfil (email, nome, etc.) vivem no Conexão e são buscados via API.
model Usuario {
  id       String    @id   // = ID do usuário no Conexão Abrasel
  isAdmin  Boolean   @default(false)
  empresas Empresa[]
}

// Empresa é um mapeamento mínimo: id do Conexão → surveyToken exclusivo do NR-1.
// Dados da empresa (nome, CNPJ, etc.) vivem no Conexão e são buscados via API.
model Empresa {
  id          String      @id        // = ID da empresa no Conexão Abrasel
  surveyToken String      @unique    @default(uuid())
  usuarioId   String
  createdAt   DateTime    @default(now())
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  respostas   Resposta[]
  relatorios  Relatorio[]
}

// Administradores da plataforma NR-1 (equipe Abrasel).
// Autenticação local com email + senha — completamente separada do SSO/Conexão.
// Admins NÃO são necessariamente usuários do Conexão.
model Admin {
  id    String @id @default(cuid())
  email String @unique
  senha String  // bcrypt hash
}

model Resposta {
  id        String   @id @default(cuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  respostas String
  createdAt DateTime @default(now())
}

model Relatorio {
  id             String   @id @default(cuid())
  empresaId      String
  empresa        Empresa  @relation(fields: [empresaId], references: [id])
  totalRespostas Int
  mediaGeral     Float
  mediaDimensao1 Float
  mediaDimensao2 Float
  mediaDimensao3 Float
  categoria      String
  planoAcaoIA    String
  createdAt      DateTime @default(now())
}
